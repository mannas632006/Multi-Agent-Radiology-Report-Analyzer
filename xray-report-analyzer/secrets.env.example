# Copy this file to C:\xray-agent\secrets.env (kept OUTSIDE the repo so keys
# never sync or get committed) and fill in your real values. The launcher
# scripts read it from that fixed path.
#
#   copy secrets.env.example C:\xray-agent\secrets.env
#   notepad C:\xray-agent\secrets.env

# --- Required API keys ---
GEMINI_API_KEY=PASTE_YOUR_GEMINI_KEY_HERE
DEEPSEEK_API_KEY=PASTE_YOUR_DEEPSEEK_KEY_HERE

# --- Required: n8n credential-store encryption key (generate a random string) ---
# PowerShell: [Convert]::ToBase64String((1..32|%{Get-Random -Max 256}))
N8N_ENCRYPTION_KEY=PASTE_A_RANDOM_SECRET_HERE

# --- Local backends / paths ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
XRAY_OUT_DIR=C:\xray-agent\out

# --- DeepSeek routing ---
# DeepSeek's two roles (specialist #3 + synthesis) run on Gemini when this is 1.
# Set to 0 only once your DeepSeek account has balance (otherwise HTTP 402).
XRAY_NO_DEEPSEEK=1

# --- Optional model / tuning overrides (uncomment to change) ---
#GEMINI_TRIAGE_MODEL=gemini-2.5-flash
#GEMINI_SPECIALIST_MODEL=gemini-2.5-flash
#GEMINI_SYNTHESIS_MODEL=gemini-2.5-flash
#DEEPSEEK_SPECIALIST_MODEL=deepseek-v4-flash
#DEEPSEEK_SYNTHESIS_MODEL=deepseek-v4-pro
#OLLAMA_MODEL=llama3.1:8b
#OLLAMA_TIMEOUT_MS=115000
#XRAY_FANOUT_CEILING_MS=120000
